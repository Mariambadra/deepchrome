.data import Dataset, DataLoader\n# PyTorch Dataset \nclass GeneDataset(Dataset):\n    def __init__(self, X, y):\n        self.X = torch.tensor(X, dtype=torch.float32)\n        self.y = torch.tensor(y, dtype=torch.long)\n\n    def __len__(self):\n        return len(self.X)\n\n    def __getitem__(self, idx):\n        return self.X[idx], self.y[idx]\n#  DataLoaders\ntrain_loader = DataLoader(GeneDataset(X_train, y_train), batch_size=1,  shuffle=True)\nval_loader   = DataLoader(GeneDataset(X_val,   y_val),   batch_size=64, shuffle=False)\ntest_loader  = DataLoader(GeneDataset(X_test,  y_test),  batch_size=64, shuffle=False)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T20:26:56.028120Z","iopub.execute_input":"2026-04-08T20:26:56.028448Z","iopub.status.idle":"2026-04-08T20:26:56.056203Z","shell.execute_reply.started":"2026-04-08T20:26:56.028411Z","shell.execute_reply":"2026-04-08T20:26:56.055594Z"}},"outputs":[],"execution_count":40},{"cell_type":"markdown","source":"# Training","metadata":{}},{"cell_type":"code","source":"#Setup \ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nprint(f\"Using device: {device}\")\n\n# setting a seed matching the same seed the author selected\ntorch.manual_seed(1)\n#moving the model's parameters to the GPU\nmodel = DeepChrome().to(device)\n#using the same optimizer and criterion as the author's\noptimizer = optim.SGD(model.parameters(), lr=1e-3, weight_decay=0, momentum=0)\ncriterion = nn.NLLLoss()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T20:26:59.637480Z","iopub.execute_input":"2026-04-08T20:26:59.637772Z","iopub.status.idle":"2026-04-08T20:26:59.650864Z","shell.execute_reply.started":"2026-04-08T20:26:59.637745Z","shell.execute_reply":"2026-04-08T20:26:59.650198Z"}},"outputs":[{"name":"stdout","text":"Using device: cuda\n","output_type":"stream"}],"execution_count":41},{"cell_type":"code","source":"#Training loop\nn_epochs = 100\ntrain_losses, val_losses,