l_auroc    = roc_auc_score(all_labels, all_probs)\n\n        # Track best AUROC seen in this trial\n        if avg_val_loss < best_val_loss:\n            best_val_loss = avg_val_loss\n            best_auroc    = val_auroc\n            epochs_without_improvement = 0\n        else:\n            epochs_without_improvement += 1\n            if epochs_without_improvement >= patience:\n                break\n\n        trial.report(val_auroc, epoch)\n        if trial.should_prune():\n            raise optuna.exceptions.TrialPruned()\n\n    return best_auroc","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T20:22:27.153421Z","iopub.execute_input":"2026-04-08T20:22:27.153756Z","iopub.status.idle":"2026-04-08T20:22:27.166453Z","shell.execute_reply.started":"2026-04-08T20:22:27.153727Z","shell.execute_reply":"2026-04-08T20:22:27.165852Z"}},"outputs":[],"execution_count":33},{"cell_type":"code","source":"study = optuna.create_study(\n    direction='maximize',\n    sampler=TPESampler(seed=1) \n)\n\nprint(\"Starting Optuna search — 30 trials...\")\nprint(\"This will take a while. Progress prints every 5 completed trials.\\n\")\n\ndef print_callback(study, trial):\n    if trial.number % 5 == 0:\n        print(f\"Trial {trial.number:3d} | AUROC: {trial.value:.4f} | Best so far: {study.best_value:.4f} | Params: {trial.params}\")\n\nstudy.optimize(objective, n_trials=30, callbacks=[print_callback])","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T18:54:38.459814Z","iopub.execute_input":"2026-04-08T18:54:38.460076Z","iopub.status.idle":"2026-04-08T20:19:15.394310Z","shell.execute_reply.started":"2026-04-08T18:54:38.460054Z","shell.execute_reply":"2026-04-08T20:19:15.393399Z"}},"outputs":[{"name":"stdout","text":"Starting Optuna search — 30 trials...\nThis will take a while. Progress prints every 5 completed trials.\n\nTrial   0 | AUROC: 0.9163 | Best so far: 0.9163 | Params: {'lr': 0.0006824078427098838, 'dropout': 0.5881297973768632, 'we