    "rows = []\n",
    "for gene_id, row in df.iterrows():\n",
    "    label = row['label']\n",
    "    # Get 500 features and reshape to (100, 5), 100 bins, 5 histone marks\n",
    "    features = row.drop('label').values.reshape(100, 5)\n",
    "    \n",
    "    for bin_num in range(100):\n",
    "        bin_features = features[bin_num]\n",
    "        rows.append([\n",
    "            gene_id,\n",
    "            bin_num + 1,\n",
    "            bin_features[0],  # H3K4me3\n",
    "            bin_features[1],  # H3K4me1\n",
    "            bin_features[2],  # H3K36me3\n",
    "            bin_features[3],  # H3K9me3\n",
    "            bin_features[4],  # H3K27me3\n",
    "            int(label)\n",
    "        ])"
   ]
